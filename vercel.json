{
    "version": 2,
    "framework": null,
    "builds": [
        { "src": "composer.json", "use": "@vercel/php" },
        { "src": "public/**/*", "use": "@vercel/static" }
    ],
    "devCommand": "php -S 0.0.0.0:8000 -t public",
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|fonts|favicon.ico)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}